# Non-SIMD subset of upstream sightglass benchmarks at
#   https://github.com/bytecodealliance/sightglass
#   pinned commit 789ac0957b7f4932382bcdf4e8dcc09c4f044702
#
# Generated by:
#   for w in benchmarks/**/*.wasm; do
#     wasm2wat --disable-simd "$w" >/dev/null 2>&1 && echo "$w"
#   done
#
# Paths are written relative to ${SIGHTGLASS_DIR}, expanded by the sweep
# driver (utils/run_sightglass_cli_sweep.sh). Run utils/setup_bench_deps.sh
# once on a fresh checkout to fetch sightglass at the pinned commit, the
# OpenVINO 2022.2 toolkit, and the mobilenet model used by image-classification.
#
# image-classification needs the WASI-NN OpenVINO plugin (built by configuring
# WasmEdge with -DWASMEDGE_PLUGIN_WASI_NN_BACKEND=OpenVINO) and OpenVINO's
# runtime libraries on LD_LIBRARY_PATH. The sweep driver auto-sources
# OpenVINO's setupvars.sh when present and exports WASMEDGE_PLUGIN_PATH.
#
# tract-onnx-image-classification is omitted — its 27 MB binary + bundled
# assets directory don't fit the simple --working-dir model. Tracking task
# in CLAUDE-level memory; not in scope here.
#
# libsodium-sodium_utils{2,3} are omitted — they import `bench.start` but not
# `bench.end` (verified via `wasm2wat | grep bench`), so the Execution-phase
# timer is never stopped and no measurement is recorded. Upstream-wasm
# structural issue; would require rebuilding the kernels from libsodium
# against a current sightglass.h.

